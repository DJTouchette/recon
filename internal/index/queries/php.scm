; PHP symbols.

(class_declaration name: (name) @class) @def
(interface_declaration name: (name) @interface) @def
(trait_declaration name: (name) @trait) @def
(enum_declaration name: (name) @enum) @def

(function_definition name: (name) @function) @def
(method_declaration name: (name) @method) @def

(namespace_definition name: (namespace_name) @module) @def
